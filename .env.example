# NVIDIA-hosted Kimi K2 configuration
WAVE_AI_BASE_URL=https://integrate.api.nvidia.com/v1
WAVE_AI_API_KEY=replace_with_your_key
WAVE_AI_MODEL=moonshotai/kimi-k2-thinking
WAVE_AI_TEMPERATURE=1
WAVE_AI_TOP_P=0.9
WAVE_AI_MAX_TOKENS=16384
WAVE_AI_CONNECT_TIMEOUT_SEC=5
WAVE_AI_READ_TIMEOUT_SEC=16

# Optional: tune report detail
WAVE_REPORT_MAX_EVENTS=500
WAVE_SEARCH_MAX_LIMIT=100

# Runtime hardening
WAVE_ENV=development
WAVE_LOG_LEVEL=INFO
WAVE_RESTRICT_TO_LOOPBACK=true
WAVE_RATE_LIMIT_ENABLED=true
WAVE_API_RATE_LIMIT_PER_MINUTE=240
WAVE_SQLITE_BUSY_TIMEOUT_MS=5000
WAVE_GZIP_MINIMUM_SIZE=1024
WAVE_ALLOWED_HOSTS=127.0.0.1,localhost
WAVE_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
WAVE_REQUEST_ID_HEADER=X-Request-ID

# Optional: fixed API token (if omitted, Wave generates a random token each run)
# WAVE_API_TOKEN=replace_with_random_secret

# Required in production mode
# WAVE_ENV=production
# WAVE_API_TOKEN=replace_with_long_random_secret
